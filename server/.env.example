# PostgreSQL — Railway lo genera automáticamente
DATABASE_URL=postgresql://user:password@host:5432/dbname

# URL pública de este servidor (sin trailing slash)
BASE_URL=https://api.lubriplan.com

# Puerto local (Railway lo sobreescribe)
PORT=3001

# Credenciales del admin (cambiá esto en Railway)
ADMIN_EMAIL=admin@lubriplan.com
ADMIN_PASSWORD=admin123

# Secreto para firmar los JWT (clave larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_segura_larga

# URL del frontend (para CORS)
FRONTEND_URL=https://card.lubriplan.com
