# Desarrollo local — apunta al backend local
VITE_API_URL=http://localhost:3001

# URL base para QR (IMPORTANTE: afecta el código del QR)
#
# PARA DESARROLLO (localhost):
#   Si quieres que funcione en otro dispositivo en la MISMA RED:
#   1. Obtén tu IP local: En Windows: ipconfig | busca "IPv4 Address" (192.168.x.x)
#   2. Reemplaza la IP abajo:
VITE_QR_BASE_URL=http://192.168.1.100:5173
#
# Para localhost (NO funciona en otro dispositivo):
# VITE_QR_BASE_URL=http://localhost:5173
#
# PARA PRODUCCIÓN:
#   Usa tu dominio o URL de producción
# VITE_QR_BASE_URL=https://tudominio.com
